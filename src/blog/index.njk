---
layout: base.njk
title: "Reports"
description: "Technical writing on software, engineering, and things I'm figuring out."
---
<div class="container">

  <header class="page-header">
    <div class="section-label">// OUTIE REPORTS</div>
    <h1>Blog</h1>
    <p class="hero-bio">Technical writing on software, engineering, and things I'm figuring out.</p>
  </header>

  {% if collections.posts.length %}
  <div class="posts-list">
    {% for post in collections.posts | reverse %}
    <article class="post-item">
      <div class="post-date-col">{{ post.date | dateCode }}</div>
      <div class="post-content-col">
        <h3><a href="{{ post.url | url }}">{{ post.data.title }}</a></h3>
        {% if post.data.description %}
        <p>{{ post.data.description }}</p>
        {% endif %}
        {% if post.data.tags %}
        <div class="post-tags">
          {% for tag in post.data.tags %}
          {% if tag != "posts" %}<span class="tag">{{ tag }}</span>{% endif %}
          {% endfor %}
        </div>
        {% endif %}
      </div>
    </article>
    {% endfor %}
  </div>
  {% else %}
  <p class="text-dim" style="padding: 3rem 0;">// NO REPORTS ON FILE YET.</p>
  {% endif %}

</div>
